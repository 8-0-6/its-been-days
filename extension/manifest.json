{
  "manifest_version": 3,
  "name": "It's Been Days",
  "version": "0.1.0",
  "description": "Track how long your tabs have been inactive. Instantly retrieve closed tabs.",
  "permissions": [
    "tabs",
    "storage",
    "notifications",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "optional_permissions": ["history"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "It's Been Days",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "toggle-overlay": {
      "suggested_key": {
        "mac": "Command+Shift+Space",
        "windows": "Ctrl+Shift+Space",
        "linux": "Ctrl+Shift+Space"
      },
      "description": "Open the It's Been Days tab search overlay"
    }
  },
  "options_page": "settings/settings.html",
  "web_accessible_resources": [
    {
      "resources": [
        "overlay/overlay.js",
        "overlay/overlay.css",
        "overlay/overlay-standalone.html",
        "overlay/overlay-standalone.js",
        "overlay/overlay-standalone.css",
        "icons/icon16.png",
        "icons/icon32.png",
        "icons/icon48.png",
        "icons/icon128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
